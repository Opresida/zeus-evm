# ═══════════════════════════════════════════════════════════════
# ZEUS EVM — Variaveis de ambiente
# Copie para .env e preencha. NUNCA commitar .env.
# ═══════════════════════════════════════════════════════════════

# ─── Chain / RPC ───
# Provider primario: Alchemy (free ja inclui archive). O liquidator E o backrun fazem failover
# automatico (viem) se o primario limitar/cair — nome da chave: BASE_RPC_HTTP_FALLBACK.
BASE_RPC_HTTP="https://base-mainnet.g.alchemy.com/v2/YOUR_KEY"
BASE_RPC_WS="wss://base-mainnet.g.alchemy.com/v2/YOUR_KEY"
BASE_RPC_HTTP_FALLBACK="https://base.publicnode.com"
# RPC com ARCHIVE p/ os fork tests (forge). Precisa servir estado em bloco historico — Alchemy free
# serve; dRPC/publicnode free NAO. Usado por `pnpm contracts:test:fork` (cai p/ BASE_RPC_HTTP).
BASE_RPC_ARCHIVE="https://base-mainnet.g.alchemy.com/v2/YOUR_KEY"

# Mempool subscription (Alchemy Mempool API ou Blocknative)
ALCHEMY_API_KEY=""
BLOCKNATIVE_API_KEY=""

# ─── Wallet ───
# Chave privada do bot (executor) — IDEALMENTE usar hardware wallet ou MPC (Turnkey, Fireblocks)
# NUNCA commitar uma chave real. Esta env e so referencia.
EXECUTOR_PRIVATE_KEY=""
EXECUTOR_ADDRESS=""

# Multisig opcional pra owner do contrato (Safe Wallet)
EXECUTOR_OWNER_ADDRESS=""

# ─── Estrategia ───
# Cap maximo por trade (em ETH) — circuit breaker
MAX_TRADE_ETH="0.5"

# Lucro minimo pra disparar tx (em USD)
MIN_PROFIT_USD="5"

# Slippage tolerado (basis points)
MAX_SLIPPAGE_BPS="50"  # 0.5%

# Trava-mestra de segurança. Default true = TRAVADO (fail-safe).
# Pra rodar LIQUIDATOR_MODE=mainnet (capital real), TEM que setar explicitamente false — senão o
# boot é RECUSADO. dryrun/testnet ignoram (sem capital real). É a trava explícita pré-mainnet.
KILL_SWITCH="true"

# ─── Flashloan ───
# Provider primario
FLASHLOAN_PROVIDER="aave-v3"  # ou "balancer", "uniswap-v3"

# Aave V3 Base Pool address (mainnet)
AAVE_V3_POOL="0xA238Dd80C259a72e81d7e4664a9801593F98d1c5"

# ─── Liquidations ───
# Aave V3 e Compound III pra monitorar
ENABLE_LIQUIDATIONS="false"  # true quando estrategia validada

# ─── Monitoring / Alerts ───
DISCORD_WEBHOOK_URL=""
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# Tenderly (opcional, pra alerts on-chain)
TENDERLY_ACCESS_KEY=""
TENDERLY_USER=""
TENDERLY_PROJECT=""

# ─── Logs ───
LOG_LEVEL="info"  # debug | info | warn | error

# ─── Database (futuro — quando persistir trades) ───
# DATABASE_URL=""  # Neon Postgres

# ─── Deploy de contracts ───
# Etherscan/BaseScan API pra verificacao automatica
BASESCAN_API_KEY=""

# ─── Motor 1: pré-liquidação Morpho (callback+swap, zero capital, stable-only) ───
MORPHO_PRELIQ_ENABLED="false"        # liga discovery+pipeline de pré-liquidação
PRE_LIQUIDATOR_ADDRESS=""            # ZeusMorphoPreLiquidator deployado (vazio = só DRY_RUN log)

# ─── Motor 1: controle remoto de execução (painel → engine_control) ───
# Armado-mas-travado: em testnet/mainnet, o ENVIO (clássico + pré-liq) só passa quando o painel ligar.
# Sem SUPABASE_URL → controle remoto inativo (envia conforme o LIQUIDATOR_MODE). Fail-safe: erro = travado.
# SUPABASE_URL/KEY são COMPARTILHADOS com o mis-scanner (mesmo projeto) — se o Motor 2 já usa o painel,
# já estão setados. O motor do liquidator tem default 'motor1' — NÃO reusar ENGINE_CONTROL_MOTOR
# (essa é do mis-scanner = motor2).
SUPABASE_URL=""                                 # já setado se o Motor 2 usa o painel
SUPABASE_KEY=""                                 # anon key — o bot só LÊ engine_control
# LIQUIDATOR_ENGINE_CONTROL_MOTOR="motor1"      # opcional — já é o default

# ─── Motor 1: wallet-pool (presença paralela no grind de pré-liquidação) ───
# 🔑 CHAVE-MESTRA: o pool acende quando a SEED (WALLET_POOL_MNEMONIC) existe + o toggle de execução liga.
# NÃO precisa mais de WALLET_POOL_ENABLED=true (virou override/legado). ⚠️ SÓ preencha a seed com as
# carteiras do pool ABASTECIDAS com gás. Escopo: só a PRÉ-LIQUIDAÇÃO usa o pool; a liquidação clássica usa a main.
WALLET_POOL_ENABLED="false"                      # legado/override — a seed presente já basta pra construir
WALLET_POOL_MNEMONIC=""                          # ⚠️ seed-mestre BIP-39 DEDICADA — nunca reusar de outro projeto; presente = pool ATIVO no toggle
WALLET_POOL_SIZE="22"                            # ~metade do líder (44)
WALLET_POOL_START_INDEX="0"
WALLET_POOL_MAX_AGGREGATE_ETH="0.2"             # ⚠️ teto de exposição AGREGADA (soma de TODOS os senders)
WALLET_POOL_MAX_CONCURRENT="8"                  # ⚠️ máx de fills SIMULTÂNEAS entre os senders (breaker v1)
WALLET_POOL_GAS_MIN_ETH="0.003"                 # gatilho de top-up de gás por EOA
WALLET_POOL_GAS_TARGET_ETH="0.01"               # alvo pós-top-up (≥ min)

# Dune Analytics — calibração de slippage por DEX (#5) + feed de inteligência (recon/backtest). Ver dune/README.md
DUNE_API_KEY=

# ═══════════════════════════════════════════════════════════════
# INVENTÁRIO DE FERRAMENTAS (cruzar possibilidades) — ver CLAUDE.md §"🧰 Ferramentas"
# ═══════════════════════════════════════════════════════════════
# --- RPC hot-path (tempo real) + fork tests ---
AVALANCHE_RPC_HTTP=            # fork tests Avalanche (Aave V3); sem ela, 1 fork skipa
# --- Painel (bot → Supabase → frontend) ---
GENERIC_WEBHOOK_URL=          # <URL do painel Vercel>/api/ingest (bot manda heartbeat/eventos)
ZEUS_WEBHOOK_SECRET=          # segredo compartilhado bot↔painel (header x-zeus-secret)
# --- Dados / aceleradores ---
THEGRAPH_API_KEY=             # subgraph Aave V3 (SÓ acelerador; discovery on-chain roda sem)
# --- Automações (Parte 3) — observe-first, default OFF (só injetam quando ligadas) ---
ADAPTIVE_THRESHOLDS_ENABLED=false   # #1 piso de EV auto-calibrável (ou acende junto com o toggle de execução)
ADAPTIVE_COOLDOWN_ENABLED=false     # #4 cooldown adaptativo (backoff)
COOLDOWN_MAX_SEC=1800               # teto do cooldown adaptativo (30min)
# --- Wallet-pool (Motor 2 paralelo) — acende com a chave-mestra OU force-on ---
# WALLET_POOL_SIZE=22                # nº de EOAs paralelas
# WALLET_POOL_MAX_INFLIGHT_ETH=5     # teto agregado de exposição em voo
