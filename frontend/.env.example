# ===== ZEUS Command — variáveis de ambiente =====
# Copie para .env.local (dev) e configure no Vercel (prod).

# --- Supabase (Postgres + Realtime) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...                 # anon/public key (RLS protege)
SUPABASE_SERVICE_ROLE_KEY=eyJ...                     # service role — SÓ no servidor (/api)

# --- Webhook de ingestão (o bot ZEUS POSTa eventos aqui) ---
# Setar no ZEUS: GENERIC_WEBHOOK_URL=https://<app>.vercel.app/api/ingest
ZEUS_WEBHOOK_SECRET=troque-por-um-segredo-forte      # validado no header x-zeus-secret

# --- Web Push (VAPID) ---
# Gere com: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:humbertodeassuncao@gmail.com

# --- Email (Resend) ---
RESEND_API_KEY=re_...
ALERT_EMAIL_TO=humbertodeassuncao@gmail.com
ALERT_EMAIL_FROM=zeus@seu-dominio.com

# --- Chain / explorer (default Base mainnet) ---
NEXT_PUBLIC_EXPLORER_URL=https://basescan.org
