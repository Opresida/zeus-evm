{
  "annotations": { "list": [] },
  "description": "ZEUS EVM — Performance, Latency & Competitor Dashboard (Item 16B OB4). Foco em hot path: dispatch latency, calculator timing, competitor profiles, scanner throughput, process health.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "area" },
      "title": "Dispatch p50",
      "type": "stat",
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum by (le) (rate(zeus_dispatch_duration_seconds_bucket[5m])))",
          "legendFormat": "p50"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "area" },
      "title": "Dispatch p95",
      "type": "stat",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(zeus_dispatch_duration_seconds_bucket[5m])))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 200 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "id": 3,
      "options": { "colorMode": "background", "graphMode": "area" },
      "title": "Event Loop Lag",
      "type": "stat",
      "targets": [
        { "expr": "max(zeus_event_loop_lag_ms)", "legendFormat": "{{service}}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 512 },
              { "color": "red", "value": 1024 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "id": 4,
      "options": { "colorMode": "background", "graphMode": "area" },
      "title": "RSS Memory",
      "type": "stat",
      "targets": [
        { "expr": "max(zeus_process_memory_rss_mb)", "legendFormat": "{{service}}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "id": 5,
      "title": "Dispatch Latency Distribution",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum by (le, chain) (rate(zeus_dispatch_duration_seconds_bucket[5m])))",
          "legendFormat": "p50 {{chain}}"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, chain) (rate(zeus_dispatch_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{chain}}"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le, chain) (rate(zeus_dispatch_duration_seconds_bucket[5m])))",
          "legendFormat": "p99 {{chain}}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "id": 6,
      "title": "Calculator Latency Distribution",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum by (le, protocol) (rate(zeus_calculator_duration_seconds_bucket[5m])))",
          "legendFormat": "p50 {{protocol}}"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, protocol) (rate(zeus_calculator_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{protocol}}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "id": 7,
      "title": "Competitor Profiles Tracked",
      "type": "timeseries",
      "targets": [
        { "expr": "zeus_competitor_profiles_total", "legendFormat": "{{chain}}" },
        { "expr": "zeus_competitor_category_total", "legendFormat": "{{category}} {{chain}}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "id": 8,
      "title": "Block Scanner Throughput",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(zeus_scanner_blocks_processed_total[1m]) * 60",
          "legendFormat": "{{chain}} blocks/min"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 30 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "id": 9,
      "title": "Event Loop Lag Over Time",
      "type": "timeseries",
      "targets": [
        { "expr": "zeus_event_loop_lag_ms", "legendFormat": "{{service}}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "decmbytes" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "id": 10,
      "title": "Process Memory Trend",
      "type": "timeseries",
      "targets": [
        { "expr": "zeus_process_memory_rss_mb", "legendFormat": "{{service}}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "id": 11,
      "title": "Uptime",
      "type": "timeseries",
      "targets": [
        { "expr": "zeus_uptime_seconds", "legendFormat": "{{service}}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Quanto o MERCADO paga de priority fee (gwei) pra ganhar inclusão — agregado dos competidores ativos. É o piso que o nosso BribeCalculator respeita (Fase 1 market-bribe).",
      "fieldConfig": { "defaults": { "unit": "none" } },
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 36 },
      "id": 12,
      "title": "Market Bribe — Priority Fee dos Competidores (gwei)",
      "type": "timeseries",
      "targets": [
        { "expr": "zeus_market_bribe_priority_fee_gwei{percentile=\"p50\"}", "legendFormat": "p50 {{chain}}" },
        { "expr": "zeus_market_bribe_priority_fee_gwei{percentile=\"p75\"}", "legendFormat": "p75 {{chain}} (piso)" },
        { "expr": "zeus_market_bribe_priority_fee_gwei{percentile=\"p95\"}", "legendFormat": "p95 {{chain}} (cauda)" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Competidores ativos considerados no agregado de market-bribe.",
      "fieldConfig": { "defaults": { "unit": "short" } },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 36 },
      "id": 13,
      "options": { "colorMode": "value", "graphMode": "area" },
      "title": "Competidores Ativos (market-bribe)",
      "type": "stat",
      "targets": [
        { "expr": "max(zeus_market_bribe_competitors_active)", "legendFormat": "{{chain}}" }
      ]
    }
  ],
