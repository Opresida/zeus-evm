{
  "name": "@zeus-evm/discovery-scraper",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "run:base": "tsx src/index.ts --chain base",
    "run:optimism": "tsx src/index.ts --chain optimism",
    "run:all": "tsx src/index.ts --all",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@zeus-evm/aave-discovery": "workspace:*",
    "@zeus-evm/chain-config": "workspace:*",
    "dotenv": "catalog:",
    "pino": "catalog:",
    "pino-pretty": "catalog:",
    "viem": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsx": "catalog:",
    "typescript": "~5.9.2"
  }
}
